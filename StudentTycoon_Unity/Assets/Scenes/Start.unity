  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\U0001F4D6 \uD559\uC0DD\uD0A4\uC6B0\uAE30 \uB3C4\uC6C0\uB9D0\n\n\uD559\uC0DD\uD0A4\uC6B0\uAE30\uB294
    \uB2E4\uC591\uD55C \uACFC\uBAA9\uC744 \uACF5\uBD80\uD558\uBA70 \uB2A5\uB825\uCE58\uB97C
    \uD0A4\uC6B0\uACE0, \uC790\uC2E0\uC758 \uC120\uD0DD\uC5D0 \uB530\uB77C \uC5EC\uB7EC
    \uAC00\uC9C0 \uBBF8\uB798\uB97C \uB9DE\uC774\uD558\uB294 \uC721\uC131 \uC2DC\uBBAC\uB808\uC774\uC158
    \uAC8C\uC784\uC785\uB2C8\uB2E4.\n\n\U0001F393 \uAC8C\uC784 \uBAA9\uD45C\n\n\uD559\uC0DD
    \uC2DC\uC808\uBD80\uD130 \uAFB8\uC900\uD788 \uACF5\uBD80\uD558\uACE0 \uB2A5\uB825\uCE58\uB97C
    \uC131\uC7A5\uC2DC\uCF1C \uC6D0\uD558\uB294 \uC9C1\uC5C5\uACFC \uC778\uC0DD\uC744
    \uB9CC\uB4E4\uC5B4 \uBCF4\uC138\uC694. \uC5EC\uB7EC\uBD84\uC758 \uC120\uD0DD\uC5D0
    \uB530\uB77C \uC131\uACF5\uC801\uC778 \uC0B6\uC744 \uC0B4 \uC218\uB3C4 \uC788\uACE0,
    \uC608\uC0C1\uCE58 \uBABB\uD55C \uBBF8\uB798\uB97C \uB9DE\uC774\uD560 \uC218\uB3C4
    \uC788\uC2B5\uB2C8\uB2E4.\n\n\U0001F4DA \uACF5\uBD80\uD558\uAE30\n\uACFC\uBAA9\uC744
    \uACF5\uBD80\uD558\uBA74 \uD574\uB2F9 \uB2A5\uB825\uCE58\uAC00 \uC0C1\uC2B9\uD569\uB2C8\uB2E4.\n\uACFC\uBAA9\uB9C8\uB2E4
    \uC601\uD5A5\uC744 \uC8FC\uB294 \uB2A5\uB825\uCE58\uC640 \uC9C4\uB85C\uAC00 \uB2E4\uB985\uB2C8\uB2E4.\n\uADE0\uD615
    \uC788\uAC8C \uC131\uC7A5\uD560\uC9C0, \uD2B9\uC815 \uBD84\uC57C\uB97C \uC9D1\uC911\uC801\uC73C\uB85C
    \uD0A4\uC6B8\uC9C0\uB294 \uD50C\uB808\uC774\uC5B4\uC758 \uC120\uD0DD\uC785\uB2C8\uB2E4.\n\U0001F4CA
    \uB2A5\uB825\uCE58\n\uAD6D\uC5B4 : \uC5B8\uC5B4 \uB2A5\uB825 \uBC0F \uC758\uC0AC\uC18C\uD1B5
    \uB2A5\uB825 \uD5A5\uC0C1\n\uC218\uD559 : \uACC4\uC0B0 \uB2A5\uB825 \uBC0F \uB17C\uB9AC\uC801
    \uC0AC\uACE0 \uD5A5\uC0C1\n\uC601\uC5B4 : \uC678\uAD6D\uC5B4 \uB2A5\uB825 \uD5A5\uC0C1\n\uC0AC\uD68C
    : \uC0AC\uD68C \uC774\uD574\uB825 \uBC0F \uC0C1\uC2DD \uD5A5\uC0C1\n\uACFC\uD559
    : \uD0D0\uAD6C \uB2A5\uB825 \uBC0F \uBB38\uC81C \uD574\uACB0 \uB2A5\uB825 \uD5A5\uC0C1\n\U0001F4BC
    \uC9C4\uB85C\uC640 \uC5D4\uB529\n\n\uAC8C\uC784\uC774 \uB05D\uB098\uBA74 \uC9C0\uAE08\uAE4C\uC9C0
    \uC313\uC544\uC628 \uB2A5\uB825\uCE58\uC5D0 \uB530\uB77C \uB2E4\uC591\uD55C \uC9C1\uC5C5\uACFC
    \uC778\uC0DD\uC744 \uC0B4\uAC8C \uB429\uB2C8\uB2E4.\n"
